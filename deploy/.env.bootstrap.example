# Local-only secrets for `deploy/bootstrap.sh`.
# Copy to deploy/.env.bootstrap and `chmod 600` it. Gitignored.

# --- Target VPS --------------------------------------------------------------
VPS_HOST=203.0.113.10
VPS_PORT=22

# --- Initial access ----------------------------------------------------------
# Path to a private SSH key whose .pub you've ALREADY pasted as root's
# authorized key in the provider's web console (Beget: VPS panel -> SSH-keys).
INITIAL_SSH_USER=root
INITIAL_SSH_KEY=~/.ssh/mercury_retreat

# --- Deploy user provisioning ------------------------------------------------
DEPLOY_USER=deploy
APP_NAME=mercury

# Public key to authorize for the deploy user.
# Defaults to ${INITIAL_SSH_KEY}.pub if unset, which is fine when you reuse the
# same key for both initial root login and the deploy user.
# DEPLOY_SSH_PUBKEY_FILE=~/.ssh/mercury_retreat.pub

# --- Hardening knobs ---------------------------------------------------------
LOCK_ROOT_PASSWORD=1
